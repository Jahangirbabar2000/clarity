# AI — multi-provider routing (at least OPENAI_API_KEY is required; the others
# enable true multi-vendor LLM routing: OpenAI for critique/reasoning,
# Anthropic for creative structured writing, Google for long-context & fast classification)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Integrations
GITHUB_ACCESS_TOKEN=
JIRA_API_TOKEN=
JIRA_BASE_URL=
JIRA_USER_EMAIL=
SENTRY_AUTH_TOKEN=
DATADOG_API_KEY=
DATADOG_APP_KEY=
NOTION_API_KEY=

# Infra
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clarity?schema=public"
REDIS_URL=redis://localhost:6379

# Demo / dev fallbacks — if true, APIs return mock data when a real integration is not connected
CLARITY_USE_MOCKS=true
